execute if score #res_mode jkbw.mem matches 0 run data modify entity @e[type=text_display, tag=jkbw_txt, limit=1] text set value [{storage: "jk:bw", nbt: "txt.ready.res_mode.0.name", color: "gold"}, {storage: "jk:bw", nbt: "txt.global.char.colon"}, {translate: "entity.minecraft.item", color: "gold"}]
execute if score #res_mode jkbw.mem matches 1 run data modify entity @e[type=text_display, tag=jkbw_txt, limit=1] text set value [{storage: "jk:bw", nbt: "txt.ready.res_mode.1.name", color: "gold"}, {storage: "jk:bw", nbt: "txt.global.char.colon"}, {storage: "jk:bw", nbt: "txt.global.lvl", color: "gold"}]
execute if score #res_mode jkbw.mem matches 2 run data modify entity @e[type=text_display, tag=jkbw_txt, limit=1] text set value [{storage: "jk:bw", nbt: "txt.ready.res_mode.1.name", color: "gold"}, {storage: "jk:bw", nbt: "txt.global.char.colon"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.2.name", color: "gold"}]
execute as @e[type=item_display, tag=jkbw_show_res_mode] run data modify entity @s CustomName set from entity @e[type=text_display, tag=jkbw_txt, limit=1] text

execute if score #res_mode jkbw.mem matches 0 as @e[type=item_display, tag=jkbw_show_res_mode] run data modify entity @s item.id set value "iron_ingot"
execute if score #res_mode jkbw.mem matches 1 as @e[type=item_display, tag=jkbw_show_res_mode] run data modify entity @s item.id set value "experience_bottle"
execute if score #res_mode jkbw.mem matches 2 as @e[type=item_display, tag=jkbw_show_res_mode] run data modify entity @s item.id set value "wither_skeleton_skull"

execute if score #res_mode jkbw.mem matches 0..1 run data modify entity @e[type=text_display, tag=jkbw_ready_res_mode, limit=1] text set value [{storage: "jk:bw", nbt: "txt.ready.in_mode.p0", color: "green"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.0.name"}, "/", {storage: "jk:bw", nbt: "txt.ready.res_mode.1.name"}, {storage: "jk:bw", nbt: "txt.ready.in_mode.p1"}, {storage: "jk:bw", nbt: "txt.global.char.comma"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.0_1.p0"}, {translate: "item.minecraft.leather", color: "white"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.0_1.p1"}, {translate: "item.minecraft.wooden_sword", color: "white"}, {storage: "jk:bw", nbt: "txt.global.char.and"}, {translate: "item.minecraft.compass", color: "white"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.0_1.p2"}]
execute if score #res_mode jkbw.mem matches 2 run data modify entity @e[type=text_display, tag=jkbw_ready_res_mode, limit=1] text set value [{storage: "jk:bw", nbt: "txt.ready.in_mode.p0", color: "green"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.2.name"}, {storage: "jk:bw", nbt: "txt.ready.in_mode.p1"}, {storage: "jk:bw", nbt: "txt.global.char.comma"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.2.p0"}, {translate: "attribute.name.max_health", color: "red"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.2.p1"}, {translate: "entity.minecraft.wither", color: "aqua"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.2.p2"}, {translate: "item.minecraft.bow", color: "aqua"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.2.p3"}]
