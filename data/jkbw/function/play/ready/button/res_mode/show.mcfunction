execute if score #res_mode jkbw.mem matches 0 run data modify entity @e[type=text_display, tag=jkbw_txt, limit=1] text set value [{storage: "jk:bw", nbt: "txt.ready.res_mode.0.name", color: "gold"}, ": ", {translate: "entity.minecraft.item", color: "gold"}]
execute if score #res_mode jkbw.mem matches 1 run data modify entity @e[type=text_display, tag=jkbw_txt, limit=1] text set value [{storage: "jk:bw", nbt: "txt.ready.res_mode.1.name", color: "gold"}, ": ", {storage: "jk:bw", nbt: "txt.global.lvl", color: "gold"}]
execute if score #res_mode jkbw.mem matches 2 run data modify entity @e[type=text_display, tag=jkbw_txt, limit=1] text set value [{storage: "jk:bw", nbt: "txt.ready.res_mode.1.name", color: "gold"}, ": ", {storage: "jk:bw", nbt: "txt.ready.res_mode.2.name", color: "green"}]
execute as @e[type=item_display, tag=jkbw_show_res_mode] run data modify entity @s CustomName set from entity @e[type=text_display, tag=jkbw_txt, limit=1] text

execute if score #res_mode jkbw.mem matches 0 as @e[type=item_display, tag=jkbw_show_res_mode] run data modify entity @s item.id set value "iron_ingot"
execute if score #res_mode jkbw.mem matches 1 as @e[type=item_display, tag=jkbw_show_res_mode] run data modify entity @s item.id set value "experience_bottle"
execute if score #res_mode jkbw.mem matches 2 as @e[type=item_display, tag=jkbw_show_res_mode] run data modify entity @s item.id set value "wither_skeleton_skull"

execute if score #res_mode jkbw.mem matches 0..1 run tellraw @a[distance=..20] [{storage: "jk:bw", nbt: "txt.global.bedwars.left", color: "yellow"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.0_1.p0", color: "gold"}, {translate: "item.minecraft.leather", color: "white"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.0_1.p1", color: "gold"}, {translate: "item.minecraft.spyglass", color: "white"}, {text: ", ", color: "gold"}, {translate: "item.minecraft.wooden_sword", color: "white"}, {text: " & ", color: "gold"}, {translate: "item.minecraft.compass", color: "white"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.0_1.p2", color: "gold"}]
execute if score #res_mode jkbw.mem matches 2 run tellraw @a[distance=..20] [{storage: "jk:bw", nbt: "txt.global.bedwars.left", color: "yellow"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.2.p0", color: "green"}, {translate: "item.minecraft.spyglass", color: "white"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.2.p1", color: "green"}, {translate: "attribute.name.max_health", color: "red"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.2.p2", color: "green"}, {translate: "entity.minecraft.wither", color: "aqua"}, {translate: "item.minecraft.bow", color: "aqua"}, {storage: "jk:bw", nbt: "txt.ready.res_mode.2.p3", color: "green"}]
