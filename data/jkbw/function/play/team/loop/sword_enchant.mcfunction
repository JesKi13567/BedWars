$execute if entity @e[type=text_display, tag=jkbw_spawn_$(team), limit=1, scores={jkbw.Team.sharpness=0, jkbw.Team.knockback=0}] if items entity @s weapon.mainhand #jkbw:sword/any run item modify entity @s weapon.mainhand {function: "set_enchantments", enchantments: {}}
$execute if entity @e[type=text_display, tag=jkbw_spawn_$(team), limit=1, scores={jkbw.Team.sharpness=1, jkbw.Team.knockback=0}] if items entity @s weapon.mainhand #jkbw:sword/any run item modify entity @s weapon.mainhand {function: "set_enchantments", enchantments: {sharpness: 1}}
$execute if entity @e[type=text_display, tag=jkbw_spawn_$(team), limit=1, scores={jkbw.Team.sharpness=0, jkbw.Team.knockback=1}] if items entity @s weapon.mainhand #jkbw:sword/any run item modify entity @s weapon.mainhand {function: "set_enchantments", enchantments: {knockback: 1}}
$execute if entity @e[type=text_display, tag=jkbw_spawn_$(team), limit=1, scores={jkbw.Team.sharpness=1, jkbw.Team.knockback=1}] if items entity @s weapon.mainhand #jkbw:sword/any run item modify entity @s weapon.mainhand {function: "set_enchantments", enchantments: {sharpness: 1, knockback: 1}}
