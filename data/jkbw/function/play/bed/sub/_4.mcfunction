$scoreboard players set @e[type=text_display, tag=jkbw_bed_$(team), limit=1] jkbw.Bed.State 1
$execute if score #bed_type jkbw.mem matches 0..1 run tellraw @a ["\n", {selector: "@s"}, {storage: "jk:bw", nbt: "txt.play.break.ed"}, {storage: "jk:bw", nbt: "txt.team.$(team)", color: "$(color)", bold: true}, " ", {storage: "jk:bw", nbt: "txt.global._s"}, {storage: "jk:bw", nbt: "txt.global.bed"}, "!\n"]
$execute if score #bed_type jkbw.mem matches 2 run tellraw @a ["\n", {selector: "@s"}, {storage: "jk:bw", nbt: "txt.play.break.ed"}, {storage: "jk:bw", nbt: "txt.team.$(team)", color: "$(color)", bold: true}, " ", {storage: "jk:bw", nbt: "txt.global._s"}, {translate: "block.minecraft.cake"}, "!\n"]
