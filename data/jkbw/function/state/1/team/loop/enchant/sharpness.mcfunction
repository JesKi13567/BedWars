$execute if score $$(team) jkbw.Team.sharpness matches 0 run item modify entity @s weapon.mainhand {function: "set_enchantments", enchantments: {knockback: $(lvl), sharpness: 0}}
$execute if score $$(team) jkbw.Team.sharpness matches 1 run item modify entity @s weapon.mainhand {function: "set_enchantments", enchantments: {knockback: $(lvl), sharpness: 1}}
$execute if score $$(team) jkbw.Team.sharpness matches 2 run item modify entity @s weapon.mainhand {function: "set_enchantments", enchantments: {knockback: $(lvl), sharpness: 2}}
$execute if score $$(team) jkbw.Team.sharpness matches 3 run item modify entity @s weapon.mainhand {function: "set_enchantments", enchantments: {knockback: $(lvl), sharpness: 3}}
$execute if score $$(team) jkbw.Team.sharpness matches 4 run item modify entity @s weapon.mainhand {function: "set_enchantments", enchantments: {knockback: $(lvl), sharpness: 4}}
$execute if score $$(team) jkbw.Team.sharpness matches 5 run item modify entity @s weapon.mainhand {function: "set_enchantments", enchantments: {knockback: $(lvl), sharpness: 5}}

# 老版本的斧头，因属性攻击伤害会占用附魔锋利
$execute if score #attack_speed jkbw.mem matches 0 if score $$(team) jkbw.Team.sharpness matches 1 if items entity @s weapon.mainhand #jkbw:axe run item modify entity @s weapon.mainhand {function: "set_attributes", replace: false, modifiers: [{id: "attack_damage_append", attribute: "attack_damage", operation: "add_value", amount: 1.25, slot: "mainhand"}]}
$execute if score #attack_speed jkbw.mem matches 0 if score $$(team) jkbw.Team.sharpness matches 2 if items entity @s weapon.mainhand #jkbw:axe run item modify entity @s weapon.mainhand {function: "set_attributes", replace: false, modifiers: [{id: "attack_damage_append", attribute: "attack_damage", operation: "add_value", amount: 2.5, slot: "mainhand"}]}
$execute if score #attack_speed jkbw.mem matches 0 if score $$(team) jkbw.Team.sharpness matches 3 if items entity @s weapon.mainhand #jkbw:axe run item modify entity @s weapon.mainhand {function: "set_attributes", replace: false, modifiers: [{id: "attack_damage_append", attribute: "attack_damage", operation: "add_value", amount: 3.75, slot: "mainhand"}]}
$execute if score #attack_speed jkbw.mem matches 0 if score $$(team) jkbw.Team.sharpness matches 4 if items entity @s weapon.mainhand #jkbw:axe run item modify entity @s weapon.mainhand {function: "set_attributes", replace: false, modifiers: [{id: "attack_damage_append", attribute: "attack_damage", operation: "add_value", amount: 5, slot: "mainhand"}]}
$execute if score #attack_speed jkbw.mem matches 0 if score $$(team) jkbw.Team.sharpness matches 5 if items entity @s weapon.mainhand #jkbw:axe run item modify entity @s weapon.mainhand {function: "set_attributes", replace: false, modifiers: [{id: "attack_damage_append", attribute: "attack_damage", operation: "add_value", amount: 6.25, slot: "mainhand"}]}
