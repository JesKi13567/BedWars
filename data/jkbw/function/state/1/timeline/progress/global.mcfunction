scoreboard players remove #time jkbw.mem 1
scoreboard players remove #time_show jkbw.mem 1
scoreboard players add #time_s jkbw.mem 1

# 游戏进度
execute if score #time jkbw.mem = #time0 jkbw.mem run function jkbw:state/1/timeline/progress/0
execute if score #time jkbw.mem = #time1 jkbw.mem run function jkbw:state/1/timeline/progress/1
execute if score #time jkbw.mem = #time2 jkbw.mem run function jkbw:state/1/timeline/progress/2
execute if score #time jkbw.mem = #time3 jkbw.mem run function jkbw:state/1/timeline/progress/3
execute if score #time jkbw.mem = #time4 jkbw.mem run function jkbw:state/1/timeline/progress/4
execute if score #time jkbw.mem = #time5 jkbw.mem run function jkbw:state/1/timeline/progress/5
execute if score #time jkbw.mem = #time6 jkbw.mem run function jkbw:state/1/timeline/progress/final

execute if score #res_mode jkbw.mem matches 2 if score #time_state jkbw.mem matches 1 as @a[scores={jkbw.Player.ID=1..}] run attribute @s max_health base set 30
execute if score #res_mode jkbw.mem matches 2 if score #time_state jkbw.mem matches 2 as @a[scores={jkbw.Player.ID=1..}] run attribute @s max_health base set 40
execute if score #res_mode jkbw.mem matches 2 if score #time_state jkbw.mem matches 3 as @a[scores={jkbw.Player.ID=1..}] run attribute @s max_health base set 50
execute if score #res_mode jkbw.mem matches 2 if score #time_state jkbw.mem matches 4 as @a[scores={jkbw.Player.ID=1..}] run attribute @s max_health base set 60
execute if score #res_mode jkbw.mem matches 0..1 if score #time_state jkbw.mem matches 6 run effect give @a[gamemode=adventure, scores={jkbw.Player.ID=1..}] strength infinite 0 true

execute unless score #exp_mode jkbw.mem matches 4 unless score #exp_mode jkbw.mem matches 6 if score #time jkbw.mem > #time1 jkbw.mem if score #time jkbw.mem <= #time0 jkbw.mem run bossbar set jkbw:game_progress name ["", {storage: "jk:bw", nbt: "txt.play.event.next", color: "gold"}, {translate: "item.minecraft.diamond", color: "aqua"}, " ", {storage: "jk:bw", nbt: "txt.global.tier"}, " ", {text: "II", color: "aqua"}, " ", {storage: "jk:bw", nbt: "txt.play.time.left", color: "yellow"}, {score: {name: "#time_show", objective: "jkbw.mem"}}, "s"]
execute unless score #exp_mode jkbw.mem matches 4 unless score #exp_mode jkbw.mem matches 6 if score #time jkbw.mem > #time2 jkbw.mem if score #time jkbw.mem <= #time1 jkbw.mem run bossbar set jkbw:game_progress name ["", {storage: "jk:bw", nbt: "txt.play.event.next", color: "gold"}, {translate: "item.minecraft.emerald", color: "green"}, " ", {storage: "jk:bw", nbt: "txt.global.tier"}, " ", {text: "II", color: "green"}, " ", {storage: "jk:bw", nbt: "txt.play.time.left", color: "yellow"}, {score: {name: "#time_show", objective: "jkbw.mem"}}, "s"]
