# 被迫零元购
execute if score #exp_mode jkbw.mem matches 4 run function jkbw:state/1/shop/page/random/global

# 超时
execute if score #time jkbw.mem matches ..0 run function jkbw:state/1/timeline/end/timeout

# 记录
execute store result bossbar jkbw:game_progress value run scoreboard players get #time_show jkbw.mem
