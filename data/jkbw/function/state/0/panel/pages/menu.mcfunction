scoreboard players reset @s jkbw.Admin.Trigger
tag @s add jkbw_admin

function jkbw:ticks/load

tellraw @a[tag=jkbw_admin] [{text: "\n\n\n\n\n\n\n\n\n\n============= ", color: "green"}, {storage: "jk:bw", nbt: "txt.global.bedwars.datapack", color: "yellow"}, " ============\n", {storage: "jk:bw", nbt: "txt.global.current"}, {storage: "jk:bw", nbt: "txt.ready.version.name"}, {storage: "jk:bw", nbt: "txt.ready.version.num", color: "gold"}]
