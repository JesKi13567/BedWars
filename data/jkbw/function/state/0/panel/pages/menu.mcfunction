execute if score #tutorial jkbw.mem matches 0..1 run tellraw @a[tag=jkbw_admin] ["", {storage: "jk:bw", nbt: "txt.ready.step.follow", color: "aqua"}, "\n\n", {storage: "jk:bw", nbt: "txt.ready.step.name"}, "1: ", {text: "[", color: "gold"}, {storage: "jk:bw", nbt: "txt.ready.how2use.name", color: "gold", click_event: {action: "run_command", command: "/trigger jkbw.Admin.Trigger set 102"}, hover_event: {action: "show_text", value: [{storage: "jk:bw", nbt: "txt.ready.how2use.p0"}]}}, {text: "]", color: "gold"}]
