data modify entity @n[type=item_display, tag=jkbw_show_exp_mode] CustomName set from entity @n[type=text_display, tag=jkbw_txt] text

execute if score #exp_mode jkbw.mem matches 0 run data modify entity @n[type=item_display, tag=jkbw_show_exp_mode] item.id set value "barrier"
execute if score #exp_mode jkbw.mem matches 1 run data modify entity @n[type=item_display, tag=jkbw_show_exp_mode] item.id set value "ender_pearl"
execute if score #exp_mode jkbw.mem matches 2 run data modify entity @n[type=item_display, tag=jkbw_show_exp_mode] item.id set value "rabbit_foot"
execute if score #exp_mode jkbw.mem matches 3 run data modify entity @n[type=item_display, tag=jkbw_show_exp_mode] item.id set value "oak_sapling"
execute if score #exp_mode jkbw.mem matches 4 run data modify entity @n[type=item_display, tag=jkbw_show_exp_mode] item.id set value "raw_gold"
execute if score #exp_mode jkbw.mem matches 5 run data merge entity @n[type=item_display, tag=jkbw_show_exp_mode] {item: {id: "player_head", components: {profile: "JK137"}}}
execute unless score #exp_mode jkbw.mem matches 5 run data remove entity @n[type=item_display, tag=jkbw_show_exp_mode] item.components

